NODE_ENV=production
HOST=127.0.0.1
PORT=8788
LOG_LEVEL=info

# Useful for macOS launchd deployments where /opt/homebrew/bin is not present
# in the default service environment. Leave unset if your supervisor already
# provides a working PATH.
PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin

# Generate with: openssl rand -base64 32
CLAW_BRIDGE_TOKEN=replace-with-a-long-random-secret

# Message validation
MAX_MESSAGE_CHARS=1200
ALLOWED_SOURCES=siri_watch,siri_iphone,shortcuts,ios_share_sheet,watch_app

# Share Sheet uploads. Voice Memos and other files use POST /shortcuts/share
# as multipart form data. Screenshots/images use POST /shortcuts/share-file as
# a raw file body from Shortcuts Request Body: File. Native Watch app voice
# uploads use POST /watch/voice as multipart form data with an audio field.
SHARE_UPLOAD_DIR=./data/uploads
SHARE_MAX_UPLOAD_BYTES=52428800

# Optional server-side audio transcription for shared Voice Memos.
# When enabled, audio uploads are transcribed before delivery to OpenClaw.
# AUDIO_TRANSCRIBE_ENABLED=true
# AUDIO_TRANSCRIBE_CLI_BIN=openclaw
# AUDIO_TRANSCRIBE_TIMEOUT_MS=300000
# AUDIO_TRANSCRIBE_MODEL=openai-whisper/whisper-1
# AUDIO_TRANSCRIBE_LANGUAGE=en

# Optional Walkie voice replies for the iOS/watchOS apps. When a request includes
# response_mode=voice, the bridge captures the OpenClaw reply text, renders it
# with ElevenLabs, and exposes it through authenticated app response endpoints.
APP_RESPONSE_DIR=./data/app-responses
APP_RESPONSE_TTL_MS=86400000
APP_DEVICE_DIR=./data/app-devices
# ELEVENLABS_API_KEY=replace-with-elevenlabs-api-key
# ELEVENLABS_VOICE_ID=replace-with-elevenlabs-voice-id
# ELEVENLABS_MODEL_ID=eleven_v3
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# ELEVENLABS_BASE_URL=https://api.elevenlabs.io

# Optional APNs tap-to-play notifications for completed app voice replies.
# The iOS app registers device tokens at /app/devices/register. When these
# values are configured, the bridge sends a notification containing response_id
# after the voice reply audio is ready.
# APNS_TEAM_ID=replace-with-apple-team-id
# APNS_KEY_ID=replace-with-apple-key-id
# APNS_PRIVATE_KEY_PATH=/secure/local/path/AuthKey_KEYID.p8
# APNS_BUNDLE_ID=com.example.ClawBridge
# APNS_ENVIRONMENT=development

# OpenClaw delivery. The CLI adapter queues immediately and drains in the
# background so Siri/Shortcuts gets a fast response.
OPENCLAW_ADAPTER=cli
OPENCLAW_ASSISTANT_ID=openclaw
OPENCLAW_SESSION_KEY=agent:openclaw:main
OPENCLAW_CLI_BIN=openclaw
OPENCLAW_CLI_DRAIN_TIMEOUT_MS=360000
# Optional: run OpenClaw from a specific workspace directory.
# OPENCLAW_WORKDIR=/Users/example/.openclaw/workspace-main
# OPENCLAW_CLI_THINKING=minimal

# Optional: deliver the assistant reply back to a messaging channel. This is
# useful when the Shortcut should enter an existing Telegram direct session and
# OpenClaw's response should appear in Telegram.
# OPENCLAW_SESSION_KEY=agent:openclaw:telegram:default:direct:user
# OPENCLAW_DELIVER_REPLY=true
# OPENCLAW_REPLY_CHANNEL=telegram
# OPENCLAW_REPLY_TO=telegram:1234567890
# OPENCLAW_MESSAGE_STYLE=compact
# VOICE_MESSAGE_PREFIX=Sent via voice message:

# Optional HTTP ingest adapter.
# OPENCLAW_ADAPTER=http
# OPENCLAW_INGEST_URL=https://example.com/openclaw/ingest
# OPENCLAW_INGEST_TOKEN=replace-with-ingest-token

QUEUE_PATH=./data/claw-bridge-queue.jsonl
# Delivered and failed records are moved here; active queue keeps pending only.
QUEUE_ARCHIVE_PATH=./data/claw-bridge-queue.archive.jsonl
QUEUE_DRAIN_INTERVAL_MS=30000
QUEUE_MAX_ATTEMPTS=3
