NODE_ENV=production
HOST=127.0.0.1
PORT=8788
LOG_LEVEL=info

# Useful for macOS launchd deployments where /opt/homebrew/bin is not present
# in the default service environment. Leave unset if your supervisor already
# provides a working PATH.
PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin

# Generate with: openssl rand -base64 32
SIRI_BRIDGE_TOKEN=replace-with-a-long-random-secret

# Message validation
MAX_MESSAGE_CHARS=1200
ALLOWED_SOURCES=siri_watch,siri_iphone,shortcuts

# OpenClaw delivery. The CLI adapter queues immediately and drains in the
# background so Siri/Shortcuts gets a fast response.
OPENCLAW_ADAPTER=cli
OPENCLAW_ASSISTANT_ID=jay
OPENCLAW_SESSION_KEY=agent:jay:main
OPENCLAW_CLI_BIN=openclaw
OPENCLAW_CLI_DRAIN_TIMEOUT_MS=120000
# Optional: run OpenClaw from a specific workspace directory.
# OPENCLAW_WORKDIR=/Users/example/.openclaw/workspace-main
# OPENCLAW_CLI_THINKING=minimal

# Optional: deliver the assistant reply back to a messaging channel. This is
# useful when the Shortcut should enter an existing Telegram direct session and
# Jay's response should appear in Telegram.
# OPENCLAW_SESSION_KEY=agent:jay:telegram:default:direct:brian
# OPENCLAW_DELIVER_REPLY=true
# OPENCLAW_REPLY_CHANNEL=telegram
# OPENCLAW_REPLY_TO=telegram:1234567890
# OPENCLAW_MESSAGE_STYLE=compact
# SIRI_MESSAGE_PREFIX=Sent via Apple Watch voice message:

# Optional HTTP ingest adapter.
# OPENCLAW_ADAPTER=http
# OPENCLAW_INGEST_URL=https://example.com/openclaw/ingest
# OPENCLAW_INGEST_TOKEN=replace-with-ingest-token

QUEUE_PATH=./data/siri-queue.jsonl
QUEUE_DRAIN_INTERVAL_MS=30000
QUEUE_MAX_ATTEMPTS=3
