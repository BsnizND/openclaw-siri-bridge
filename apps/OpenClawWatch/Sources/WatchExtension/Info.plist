<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Claw Bridge</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>ClawBridgeDefaultBaseURL</key>
	<string>$(CLAW_BRIDGE_DEFAULT_BASE_URL)</string>
	<key>ClawBridgeDefaultBearerToken</key>
	<string>$(CLAW_BRIDGE_DEFAULT_BEARER_TOKEN)</string>
	<key>NSExtension</key>
	<dict>
		<key>NSExtensionAttributes</key>
		<dict>
			<key>WKAppBundleIdentifier</key>
			<string>$(CLAW_BRIDGE_BUNDLE_ID_PREFIX).ClawBridge.watchkitapp</string>
		</dict>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.watchkit</string>
	</dict>
	<key>NSHealthShareUsageDescription</key>
	<string>Claw Bridge can start a golf workout to keep location ready while you use Golf Mode.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Claw Bridge can record a golf workout while Golf Mode is active.</string>
	<key>NSLocationTemporaryUsageDescriptionDictionary</key>
	<dict>
		<key>PreciseWatchVoiceMessage</key>
		<string>Claw Bridge can attach precise location to a voice message when you ask location-aware questions.</string>
	</dict>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Claw Bridge can attach your current location to Watch voice messages when you allow it.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Claw Bridge records audio only when you press the Watch push-to-talk control.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<key>WKBackgroundModes</key>
	<array>
		<string>workout-processing</string>
	</array>
</dict>
</plist>
